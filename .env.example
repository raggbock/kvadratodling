# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase Postgres — https://supabase.com/dashboard/project/_/settings/database
# Use the "Transaction mode" pooler URL (port 6543) for DATABASE_URL
# Use the direct connection URL (port 5432) for DIRECT_URL (migrations)
DATABASE_URL=postgresql://postgres.project:[password]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.project.supabase.co:5432/postgres

# PostHog analytics — project key is public (phc_ prefix)
NEXT_PUBLIC_POSTHOG_KEY=phc_uSz9KA9zzTT5iDPqmmXJvzamTcQjv4h2PVEUjcv8fC5e
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

