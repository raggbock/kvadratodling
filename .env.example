# Database (Prisma)
# Local dev (SQLite): run `npx prisma db push && npx ts-node --esm prisma/seed.ts`
DATABASE_URL=file:./dev.db
# Production (Supabase Postgres): switch schema.prisma provider to "postgresql" and uncomment:
# DATABASE_URL=postgresql://user:password@host:5432/kvadratodling

# Clerk auth — https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Sentry error tracking — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

